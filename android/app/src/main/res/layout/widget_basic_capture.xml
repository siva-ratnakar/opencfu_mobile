<?xml version="1.0" encoding="utf-8"?>
<!--
  Icon-only tap target: the app icon (petri dish) with a small camera badge,
  no background chrome or label. See ic_widget_launcher, generated by
  assets/branding/gen_widget_icon.py, for the composited artwork.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_basic_capture_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_widget_launcher"
        android:contentDescription="@string/widget_basic_capture_label" />
</FrameLayout>
